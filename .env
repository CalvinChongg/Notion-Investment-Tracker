# ── Rename this file to .env and fill in your values ──────────────────────────

# Notion Integration Token
# Get it from: https://www.notion.so/my-integrations → New Integration → copy "Internal Integration Token"
NOTION_TOKEN=

# Notion Database ID
# Open your Notion database in browser → copy the ID from the URL:
# https://notion.so/yourworkspace/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=381295d88a7380ea96a7e795face933e

# Moomoo OpenD connection (leave as-is unless you changed OpenD's port)
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111

# Your Moomoo trading PIN / unlock password (needed to read positions)
MOOMOO_PWD_UNLOCK=

# Market: US or HK
MOOMOO_MARKET=US
